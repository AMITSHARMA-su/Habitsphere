@model IEnumerable<Habitsphere.Models.Activity>

@{
    ViewData["Title"] = "HabitSphere";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">HabitSphere Dashboard</h2>

    <a asp-action="Create" class="btn btn-primary">
        + Add Task
    </a>
</div>
@{
    var total = Model.Count();
    var completed = Model.Count(x => x.Completed);
    var pending = total - completed;
}
<div class="row mb-4">

    <div class="col-md-4">
        <div class="card bg-secondary text-white shadow border-primary">
            <div class="card-body">
                <h5>Total Tasks</h5>
                <h2>@total</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-secondary text-white shadow border-success">
            <div class="card-body">
                <h5>Completed</h5>
                <h2>@completed</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-secondary text-white shadow border-danger">
            <div class="card-body">
                <h5>Pending</h5>
                <h2>@pending</h2>
            </div>
        </div>
    </div>

</div>
<table class="table table-dark table-hover align-middle shadow">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Completed)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Time)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Created)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                    @if (item.Completed)
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Pending</span>
                    }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Time)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Created)
            </td>
            <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
